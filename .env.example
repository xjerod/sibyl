# =============================================================================
# Sibyl Configuration
# =============================================================================
# Copy this file to .env and update with your values.
#
# Docker Compose Quick Start:
#   cp .env.example .env
#   # Edit .env with your values (especially JWT_SECRET and OPENAI_API_KEY)
#   docker compose -f docker-compose.prod.yml up -d
#   # Visit http://localhost:3337

# -----------------------------------------------------------------------------
# Storage Mode (default: fully Surreal)
# -----------------------------------------------------------------------------
# SIBYL_STORE:              "surreal" (default) or "legacy"
# SIBYL_AUTH_STORE:         "surreal" (default) or "postgres"
# SIBYL_COORDINATION_BACKEND: "auto" (default), "local", or "redis"
#
# See docs/guide/storage-modes.md for the full mode matrix.
# SIBYL_STORE=surreal
# SIBYL_AUTH_STORE=surreal
# SIBYL_COORDINATION_BACKEND=auto

# -----------------------------------------------------------------------------
# Port Configuration
# -----------------------------------------------------------------------------
# All ports are configurable for running multiple instances
SIBYL_SERVER_PORT=3334
SIBYL_WEB_PORT=3337
SIBYL_SURREAL_PORT=8000
SIBYL_POSTGRES_PORT=5433

# Legacy (only used when SIBYL_STORE=legacy)
SIBYL_FALKORDB_PORT=6380
SIBYL_FALKORDB_BROWSER_PORT=3335

# -----------------------------------------------------------------------------
# SurrealDB Configuration (default store)
# -----------------------------------------------------------------------------
# Connection URL. Supported schemes:
#   ws://host:port/rpc        remote WebSocket (recommended for services)
#   http://host:port          remote HTTP
#   surrealkv://./path        local RocksDB (embedded, dev-friendly)
#   memory://                 in-memory (tests only; forbidden in production)
#
# Leave SIBYL_SURREAL_URL empty and set SIBYL_SURREAL_DATA_DIR to use embedded mode.
SIBYL_SURREAL_URL=ws://localhost:8000/rpc
# SIBYL_SURREAL_DATA_DIR=./.moon/cache/surreal-dev
SIBYL_SURREAL_USERNAME=
SIBYL_SURREAL_PASSWORD=
SIBYL_SURREAL_NAMESPACE_PREFIX=org_
SIBYL_SURREAL_DATABASE=graph

# -----------------------------------------------------------------------------
# Legacy FalkorDB + PostgreSQL (only used when SIBYL_STORE=legacy)
# -----------------------------------------------------------------------------
# SIBYL_FALKORDB_HOST=localhost
# SIBYL_FALKORDB_PASSWORD=sibyl_dev
# SIBYL_FALKORDB_GRAPH_NAME=sibyl

# PostgreSQL is used when SIBYL_AUTH_STORE=postgres (mixed or legacy mode)
# SIBYL_POSTGRES_HOST=localhost
# SIBYL_POSTGRES_USER=sibyl
# SIBYL_POSTGRES_PASSWORD=sibyl_dev
# SIBYL_POSTGRES_DB=sibyl

# -----------------------------------------------------------------------------
# AI Provider Configuration
# -----------------------------------------------------------------------------
# Embeddings and semantic search. Choose openai or gemini.
SIBYL_EMBEDDING_PROVIDER=openai
SIBYL_OPENAI_API_KEY=sk-your-openai-key-here
# SIBYL_GEMINI_API_KEY=your-gemini-key-here
# Gemini also honors GEMINI_API_KEY and GOOGLE_API_KEY.

# Anthropic (required for entity extraction and agents)
SIBYL_ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# LLM Configuration (for entity extraction via Graphiti)
SIBYL_LLM_PROVIDER=anthropic
SIBYL_LLM_MODEL=claude-haiku-4-5

# Document Embedding Model Configuration
SIBYL_EMBEDDING_MODEL=text-embedding-3-small
SIBYL_EMBEDDING_DIMENSIONS=1536

# Graph Embedding Model Configuration
SIBYL_GRAPH_EMBEDDING_PROVIDER=openai
SIBYL_GRAPH_EMBEDDING_MODEL=text-embedding-3-small
SIBYL_GRAPH_EMBEDDING_DIMENSIONS=1024

# Logging
SIBYL_LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Auth (JWT + GitHub OAuth)
# -----------------------------------------------------------------------------
# Required for login and issuing access tokens
SIBYL_JWT_SECRET=dev-change-me

# GitHub OAuth (optional, required for /api/auth/github login flow)
# Create an OAuth app at https://github.com/settings/developers
SIBYL_GITHUB_CLIENT_ID=
SIBYL_GITHUB_CLIENT_SECRET=

# Public base URL for this server (used for OAuth callback URLs + invitation links)
SIBYL_SERVER_URL=http://localhost:3334

# Frontend URL to redirect to after login (can be overridden with ?redirect=...)
SIBYL_FRONTEND_URL=http://localhost:3337/

# Cookie overrides (optional)
# SIBYL_COOKIE_DOMAIN=example.com
# SIBYL_COOKIE_SECURE=true

# Local password auth (optional hardening)
# SIBYL_PASSWORD_PEPPER=change-me-in-prod
# SIBYL_PASSWORD_ITERATIONS=310000

# MCP auth (Bearer token required when enabled)
# - auto: require auth when SIBYL_JWT_SECRET is set
# - on: always require auth
# - off: disable auth for MCP endpoints
SIBYL_MCP_AUTH_MODE=auto

# -----------------------------------------------------------------------------
# Sandbox Runner Configuration (optional)
# -----------------------------------------------------------------------------
# SIBYL_SANDBOX_MODE=shadow          # off | shadow | enforced
# SIBYL_SANDBOX_DEFAULT_IMAGE=ghcr.io/hyperb1iss/sibyl-sandbox:latest
# SIBYL_SANDBOX_K8S_NAMESPACE=default
# SIBYL_SANDBOX_RECONCILE_ENABLED=true
